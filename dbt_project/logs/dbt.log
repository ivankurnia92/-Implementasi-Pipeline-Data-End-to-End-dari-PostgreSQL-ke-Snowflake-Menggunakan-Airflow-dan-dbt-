    DBT_VALID_TO as EFFECTIVE_END_DATE,
    
    case 
        when DBT_VALID_TO is null then 'CURRENT'
        else 'HISTORICAL'
    end as ROW_STATUS

-- PERBAIKAN: Gunakan nama CTE 'customer_snapshot_data', bukan 'customer_snapshot'
from customer_snapshot_data
        );
