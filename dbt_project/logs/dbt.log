create or replace transient table DBT_DEV_DB.PUBLIC_3_MART.supplier_lead_time_performance
         as
        (

with fact_purchase_order as (
    select * from DBT_DEV_DB.PUBLIC_2_STAGING.fact_purchase_order
),

dim_product as (
    select * from DBT_DEV_DB.PUBLIC_2_STAGING.dim_product where ROW_STATUS = 'CURRENT'
),

supplier_metrics as (
    select
        SUPPLIER_ID,
        PRODUCT_ID,
        
        -- 1. Menghitung Selisih Hari (Lead Time)
        -- Tanggal Barang Diterima - Tanggal Pesanan Dibuat
        datediff('day', CREATION_DATE, DATE_RECEIVED) as ACTUAL_LEAD_TIME,
        
        -- 2. Menghitung Deviasi dari Tanggal yang Dijanjikan (Expected)
        datediff('day', EXPECTED_DATE, DATE_RECEIVED) as DAYS_DIFF_FROM_EXPECTED,
        
        QUANTITY,
        UNIT_COST

    from fact_purchase_order
    -- Kita hanya hitung yang barangnya sudah benar-benar sampai (DATE_RECEIVED tidak null)
    where DATE_RECEIVED is not null
),

final_agg as (
    select
        SUPPLIER_ID,
        -- Mengambil rata-rata performa per Supplier
        round(avg(ACTUAL_LEAD_TIME), 1) as AVG_LEAD_TIME_DAYS,
        round(avg(DAYS_DIFF_FROM_EXPECTED), 1) as AVG_DELAY_DAYS,
        count(SUPPLIER_ID) as TOTAL_SHIPMENTS_RECEIVED,
        
        -- Menghitung On-Time Delivery Rate
        round(
            count(case when DAYS_DIFF_FROM_EXPECTED <= 0 then 1 end) * 100.0 / count(*), 
            2
        ) as ON_TIME_DELIVERY_PCT

    from supplier_metrics
    group by 1
)

select
    s.SUPPLIER_ID,
    -- (Opsional: Jika Anda punya dim_supplier, join di sini untuk nama vendor)
    s.AVG_LEAD_TIME_DAYS,
    s.AVG_DELAY_DAYS,
    s.TOTAL_SHIPMENTS_RECEIVED,
    s.ON_TIME_DELIVERY_PCT,
    
    -- 3. Segmentasi Supplier Berdasarkan Performa
    case 
        when s.ON_TIME_DELIVERY_PCT >= 90 then 'Class A (Reliable)'
        when s.ON_TIME_DELIVERY_PCT >= 75 then 'Class B (Average)'
        else 'Class C (Risky - Frequent Delays)'
    end as SUPPLIER_RATING

from final_agg s
order by s.ON_TIME_DELIVERY_PCT desc
        );
