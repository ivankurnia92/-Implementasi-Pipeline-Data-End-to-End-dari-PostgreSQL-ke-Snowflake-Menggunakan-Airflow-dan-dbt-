create or replace transient table DBT_DEV_DB.STAGING.dim_product
         as
        (

with product_snapshot_data as (
    /* Mengambil data dari snapshots/product_snapshot.sql */
    select * from DBT_DEV_DB.SNAPSHOTS.product_snapshot
)

select
    -- 1. Business Keys
    ID as PRODUCT_ID,
    PRODUCT_CODE,
    PRODUCT_NAME,
    DESCRIPTION,
    
    -- 2. Supplier & Category Info
    -- Pastikan nama kolom ini sesuai dengan hasil snapshot Anda
    SUPPLIER_IDS, 
    CATEGORY,
    
    -- 3. Pricing & Inventory Info
    STANDARD_COST,
    LIST_PRICE,
    REORDER_LEVEL,
    TARGET_LEVEL,
    QUANTITY_PER_UNIT,
    
    -- 4. Status Produk (Transformasi Logika)
    case 
        when DISCONTINUED = 1 then 'Discontinued'
        else 'Active'
    end as PRODUCT_STATUS,
    
    -- 5. Metadata SCD Tipe 2
    DBT_VALID_FROM as EFFECTIVE_START_DATE,
    DBT_VALID_TO as EFFECTIVE_END_DATE,
    
    -- 6. Flag Baris Aktif
    case 
        when DBT_VALID_TO is null then 'CURRENT'
        else 'HISTORICAL'
    end as ROW_STATUS

from product_snapshot_data
        );
