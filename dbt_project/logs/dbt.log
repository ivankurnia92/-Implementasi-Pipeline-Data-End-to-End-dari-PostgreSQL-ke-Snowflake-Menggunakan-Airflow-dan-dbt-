create or replace transient table DBT_DEV_DB.PUBLIC_2_STAGING.dim_employee
         as
        (

with raw_snapshot as (
    -- Ambil data dari snapshot employee
    select * from DBT_DEV_DB.SNAPSHOTS.employee_snapshot
),

deduplicated as (
    -- Melakukan deduplikasi berdasarkan employee_id (atau ID asli dari snapshot)
    select 
        *,
        row_number() over (
            partition by employee_id 
            order by dbt_updated_at desc
        ) as row_num
    from raw_snapshot
),

final as (
    select
        -- Business Key
        employee_id,
        
        -- Transformasi Nama
        first_name,
        last_name,
        concat(first_name, ' ', last_name) as full_name,
        
        -- Informasi Kontak & Pekerjaan
        company,
        email_address,
        job_title,
        mobile_phone,
        
        -- Informasi Alamat
        address,
        city,
        state_province,
        zip_postal_code,
        country_region,
        
        -- Metadata SCD Tipe 2
        dbt_valid_from as effective_start_date,
        dbt_valid_to as effective_end_date,
        
        -- Status Baris: Memastikan hanya 1 baris yang 'current'
        case 
            when row_num = 1 and dbt_valid_to is null then 'current'
            else 'historical'
        end as row_status

    from deduplicated
)

select * from final
        );
