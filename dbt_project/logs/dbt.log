create or replace transient table DBT_DEV_DB.PUBLIC_2_STAGING.fact_purchase_order
         as
        (

with source as (
    select
        -- 1. Mengambil ID dari Tabel Dimensi (menggunakan ref)
        c.CUSTOMER_ID,
        e.EMPLOYEE_ID,
        p.PRODUCT_ID,
        
        -- 2. Identifiers & Foreign Keys lainnya
        po.SUPPLIER_ID,
        pod.INVENTORY_ID,
        pod.PURCHASE_ORDER_ID,
        po.ID as PO_TRANSACTION_ID,
        
        -- 3. Metrics
        pod.QUANTITY,
        pod.UNIT_COST,
        (pod.QUANTITY * pod.UNIT_COST) as TOTAL_COST,
        pod.DATE_RECEIVED,
        pod.POSTED_TO_INVENTORY,
        
        -- 4. PO Metadata
        po.CREATED_BY,
        po.SUBMITTED_DATE,
        CAST(po.CREATION_DATE AS DATE) as CREATION_DATE,
        po.STATUS_ID,
        po.EXPECTED_DATE,
        po.SHIPPING_FEE,
        po.TAXES,
        po.PAYMENT_DATE,
        po.PAYMENT_AMOUNT,
        po.PAYMENT_METHOD,
        po.NOTES,
        po.APPROVED_BY,
        po.APPROVED_DATE,
        po.SUBMITTED_BY,
        
        -- 5. Audit
        CURRENT_TIMESTAMP() as INSERTION_TIMESTAMP

    -- Sumber data transaksi (Source)
    from "DBT_DEV_DB"."PUBLIC_1_RAW"."PURCHASE_ORDERS" po
    left join "DBT_DEV_DB"."PUBLIC_1_RAW"."PURCHASE_ORDER_DETAILS" pod
        on pod.purchase_order_id = po.id
    left join "DBT_DEV_DB"."PUBLIC_1_RAW"."ORDER_DETAILS" od
        on od.product_id = pod.product_id
    left join "DBT_DEV_DB"."PUBLIC_1_RAW"."ORDERS" o
        on o.id = od.order_id

    -- Join ke Tabel Dimensi yang sudah Anda buat sebelumnya (Ref)
    -- Kita filter 'CURRENT' agar mendapat data terbaru dari customer/employee/product
    left join DBT_DEV_DB.STAGING.dim_product p
        on p.product_id = pod.product_id 
        and p.row_status = 'CURRENT'
        
    left join DBT_DEV_DB.STAGING.dim_employee e
        on e.employee_id = po.created_by
        and e.row_status = 'CURRENT'
        
    left join DBT_DEV_DB.PUBLIC_2_STAGING.dim_customer c
        on c.customer_id = o.customer_id
        and c.row_status = 'CURRENT'
    
    where o.customer_id is not null
)

select * from source
        );
