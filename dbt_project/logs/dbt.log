create or replace transient table DBT_DEV_DB.PUBLIC_2_STAGING.dim_employee
         as
        (

with employee_snapshot_data as (
    /* Mengambil data dari hasil snapshot. 
       Pastikan sudah menjalankan 'dbt snapshot --select employee_snapshot' sebelumnya.
    */
    select * from DBT_DEV_DB.SNAPSHOTS.employee_snapshot
)

select
    -- 1. Business Key (Primary Key)
    ID as EMPLOYEE_ID,
    
    -- 2. Transformasi Nama & Identitas
    FIRST_NAME,
    LAST_NAME,
    CONCAT(FIRST_NAME, ' ', LAST_NAME) as FULL_NAME,
    
    -- 3. Informasi Kontak & Pekerjaan
    COMPANY,
    EMAIL_ADDRESS,
    JOB_TITLE,
    BUSINESS_PHONE,
    MOBILE_PHONE,
    FAX_NUMBER,
    
    -- 4. Informasi Geografis (Alamat Lengkap)
    ADDRESS,
    CITY,
    STATE_PROVINCE,
    ZIP_POSTAL_CODE,
    COUNTRY_REGION,
    
    -- 5. Metadata SCD Tipe 2 (Slowly Changing Dimension)
    DBT_VALID_FROM as EFFECTIVE_START_DATE,
    DBT_VALID_TO as EFFECTIVE_END_DATE,
    
    -- 6. Flag Status Data (Current vs Historical)
    case 
        when DBT_VALID_TO is null then 'CURRENT'
        else 'HISTORICAL'
    end as ROW_STATUS

from employee_snapshot_data
        );
