create or replace transient table DBT_DEV_DB.PUBLIC_2_STAGING.fact_sales
         as
        (

with orders as (
    -- Mengambil data mentah order
    select * from "DBT_DEV_DB"."PUBLIC_1_RAW"."ORDERS"
),

order_details as (
    -- Mengambil data mentah detail order
    select * from "DBT_DEV_DB"."PUBLIC_1_RAW"."ORDER_DETAILS"
),

-- Mengambil referensi dari tabel Dimensi yang sudah ada
dim_product as (
    select * from DBT_DEV_DB.PUBLIC_2_STAGING.dim_product where row_status = 'CURRENT'
),

dim_customer as (
    select * from DBT_DEV_DB.PUBLIC_2_STAGING.dim_customer where row_status = 'CURRENT'
),

dim_employee as (
    select * from DBT_DEV_DB.PUBLIC_2_STAGING.dim_employee where row_status = 'CURRENT'
)

select
    -- 1. Keys (Primary & Foreign Keys)
    od.ORDER_ID,
    od.PRODUCT_ID,
    o.CUSTOMER_ID,
    o.EMPLOYEE_ID,
    o.SHIPPER_ID,
    od.PURCHASE_ORDER_ID,
    od.INVENTORY_ID,

    -- 2. Sales Metrics
    od.QUANTITY,
    od.UNIT_PRICE,
    od.DISCOUNT,
    -- Kalkulasi Revenue: (Qty * Price) - (Qty * Price * Discount)
    (od.QUANTITY * od.UNIT_PRICE) * (1 - od.DISCOUNT) as NET_REVENUE,
    
    -- 3. Status & Dates
    od.STATUS_ID,
    CAST(o.ORDER_DATE AS DATE) as ORDER_DATE,
    o.SHIPPED_DATE,
    o.PAID_DATE,
    od.DATE_ALLOCATED,
    
    -- 4. Audit Metadata
    CURRENT_TIMESTAMP() as INSERTION_TIMESTAMP

from orders o
left join order_details od
    on o.id = od.order_id

-- Join ke Dimensi untuk memastikan data valid (referential integrity)
left join dim_product p on od.product_id = p.product_id
left join dim_customer c on o.customer_id = c.customer_id
left join dim_employee e on o.employee_id = e.employee_id

-- Memastikan hanya data yang memiliki detail yang masuk ke Fact
where od.order_id is not null
        );
