create or replace transient table DBT_DEV_DB.PUBLIC_2_STAGING.fact_inventory
         as
        (

with source_data as (
    select
        -- Primary Key dari transaksi inventaris
        ID as INVENTORY_TRANSACTION_ID,
        
        -- Kunci Relasi (Foreign Keys) untuk Join ke Dimensi
        PRODUCT_ID,
        PURCHASE_ORDER_ID,
        CUSTOMER_ORDER_ID,
        
        -- Detail Transaksi
        TRANSACTION_TYPE,
        QUANTITY,
        COMMENTS,
        
        -- Dimensi Waktu
        CAST(TRANSACTION_CREATED_DATE AS DATE) as TRANSACTION_DATE,
        TRANSACTION_CREATED_DATE as TRANSACTION_CREATED_AT,
        TRANSACTION_MODIFIED_DATE as TRANSACTION_MODIFIED_AT,
        
        -- Metadata Audit
        CURRENT_TIMESTAMP() as INSERTION_TIMESTAMP
        
    from "DBT_DEV_DB"."PUBLIC_1_RAW"."INVENTORY_TRANSACTIONS"
)

select 
    *,
    -- Menambahkan logika kategori transaksi agar lebih mudah di-report
    case 
        when TRANSACTION_TYPE = 1 then 'Purchased'
        when TRANSACTION_TYPE = 2 then 'Sold'
        when TRANSACTION_TYPE = 3 then 'On Hold'
        when TRANSACTION_TYPE = 4 then 'Waste'
        else 'Unknown'
    end as TRANSACTION_TYPE_NAME
from source_data
        );
